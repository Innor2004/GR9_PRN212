<UserControl x:Class="EWMS_WPF.Views.Admin.UserCreate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EWMS_WPF.Views.Admin"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- ===== COLOR PALETTE ===== -->
        <SolidColorBrush x:Key="BgPrimary"       Color="#0F1117"/>
        <SolidColorBrush x:Key="BgCard"          Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgCardHover"     Color="#22263A"/>
        <SolidColorBrush x:Key="BorderSubtle"    Color="#2E3348"/>
        <SolidColorBrush x:Key="AccentBlue"      Color="#4F8EF7"/>
        <SolidColorBrush x:Key="AccentGreen"     Color="#34D399"/>
        <SolidColorBrush x:Key="AccentRed"       Color="#F87171"/>
        <SolidColorBrush x:Key="AccentYellow"    Color="#FBBF24"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#8A93B2"/>
        <SolidColorBrush x:Key="TextMuted"       Color="#4A5270"/>

        <!-- ===== BUTTON STYLES ===== -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="#4F8EF7"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontFamily"   Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="18,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6BA3F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A78E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnEdit" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="#FBBF24"/>
            <Setter Property="FontFamily"   Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"  Value="#FBBF24"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FBBF24"/>
                                <Setter Property="Foreground" Value="#0F1117"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDelete" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="#F87171"/>
            <Setter Property="FontFamily"   Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"  Value="#F87171"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F87171"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== SEARCH BOX ===== -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#22263A"/>
            <Setter Property="Foreground"       Value="#F1F5F9"/>
            <Setter Property="CaretBrush"       Value="#F1F5F9"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="BorderBrush"      Value="#2E3348"/>
            <Setter Property="Padding"          Value="12,8"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4F8EF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== COMBOBOX ===== -->
        <Style x:Key="RoleFilter" TargetType="ComboBox">
            <Setter Property="Background"       Value="#22263A"/>
            <Setter Property="Foreground"       Value="#F1F5F9"/>
            <Setter Property="BorderBrush"      Value="#2E3348"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,7"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="MinWidth"         Value="150"/>
        </Style>

        <!-- ===== DATAGRID ===== -->
        <Style x:Key="MainGrid" TargetType="DataGrid">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Foreground"               Value="#F1F5F9"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E2235"/>
            <Setter Property="RowBackground"            Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#161929"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="ColumnHeaderHeight"       Value="42"/>
            <Setter Property="RowHeight"                Value="52"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
        </Style>

        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="#0F1117"/>
            <Setter Property="Foreground"    Value="#8A93B2"/>
            <Setter Property="FontFamily"    Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="Padding"       Value="14,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"   Value="#2E3348"/>
        </Style>

        <!-- ===== STATUS BADGE (via converter ideally; here shown as TextBlock style) ===== -->
        <Style x:Key="BadgeActive" TargetType="Border">
            <Setter Property="Background"   Value="#0E3D2A"/>
            <Setter Property="BorderBrush"  Value="#34D399"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding"      Value="10,3"/>
        </Style>
        <Style x:Key="BadgeInactive" TargetType="Border">
            <Setter Property="Background"   Value="#3D1A1A"/>
            <Setter Property="BorderBrush"  Value="#F87171"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding"      Value="10,3"/>
        </Style>
    </UserControl.Resources>

    <!-- ============================================================ -->
    <!--  ROOT                                                         -->
    <!-- ============================================================ -->
    <Grid Background="{StaticResource BgPrimary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header bar -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar / filters -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Footer / pager -->
        </Grid.RowDefinitions>

        <!-- =========================================================
             ROW 0 – PAGE HEADER
             ========================================================= -->
        <Border Grid.Row="0"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="28,18">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Icon placeholder -->
                    <Border Width="36" Height="36" CornerRadius="8" Background="#1E2A4A"
                            Margin="0,0,14,0" VerticalAlignment="Center">
                        <TextBlock Text="👤" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="User Management"
                                   FontFamily="Segoe UI Semibold" FontSize="20"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="txtSubtitle" Text="Danh sách tất cả tài khoản trong hệ thống"
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                
            </Grid>
        </Border>

        <!-- =========================================================
             ROW 1 – TOOLBAR
             ========================================================= -->
        <Border Grid.Row="1" Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: search + filter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Search -->
                    <Grid Width="280" Margin="0,0,12,0">
                        <TextBox x:Name="txtSearch"
                                 Style="{StaticResource SearchBox}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Tìm kiếm tên, email..."/>
                        <!-- Placeholder label (hide when focused via code-behind) -->
                        <TextBlock IsHitTestVisible="False"
                                   Text="🔍  Tìm kiếm tên, email..."
                                   Foreground="{StaticResource TextMuted}"
                                   FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Role filter -->
                    <ComboBox x:Name="cmbRole" Style="{StaticResource RoleFilter}"
                              SelectedIndex="{Binding RoleFilterIndex}" Margin="0,0,12,0">
                        <ComboBoxItem Content="Tất cả vai trò"/>
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="Manager"/>
                        <ComboBoxItem Content="Staff"/>
                        <ComboBoxItem Content="Viewer"/>
                    </ComboBox>

                    <!-- Status filter -->
                    <ComboBox x:Name="cmbStatus" Style="{StaticResource RoleFilter}"
                              SelectedIndex="{Binding StatusFilterIndex}">
                        <ComboBoxItem Content="Tất cả trạng thái"/>
                        <ComboBoxItem Content="Đang hoạt động"/>
                        <ComboBoxItem Content="Bị khóa"/>
                    </ComboBox>
                </StackPanel>

                <!-- Right: Add button -->
                <Button Grid.Column="1" x:Name="btnAddUser"
                        Content="＋  Thêm người dùng"
                        Style="{StaticResource BtnPrimary}"
                        Command="{Binding AddUserCommand}"/>
            </Grid>
        </Border>

        <!-- =========================================================
             ROW 2 – DATA GRID
             ========================================================= -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" Padding="0">
            <DataGrid x:Name="dgUsers"
                      ItemsSource="{Binding UserRows}"
                      Style="{StaticResource MainGrid}"
                      ColumnHeaderStyle="{StaticResource GridHeader}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      >

                <DataGrid.Columns>

                    <!-- # -->
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="14,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Avatar + Name combo -->
                    <DataGridTemplateColumn Header="NGƯỜI DÙNG" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                    <Border Width="34" Height="34" CornerRadius="17"
                                            Background="{Binding AvatarColor}" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Initials}"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI Semibold" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}"
                                                   FontFamily="Segoe UI Semibold" FontSize="13"
                                                   Foreground="#F1F5F9"/>
                                        <TextBlock Text="{Binding Email}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Foreground="#8A93B2" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Phone -->
                    <DataGridTextColumn Header="SỐ ĐIỆN THOẠI" Binding="{Binding Phone}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="14,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Role badge -->
                    <DataGridTemplateColumn Header="VAI TRÒ" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Margin="14,0" VerticalAlignment="Center"
                                        CornerRadius="4" Padding="10,4"
                                        Background="{Binding RoleBg}"
                                        BorderBrush="{Binding RoleColor}"
                                        BorderThickness="1" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Role}"
                                               Foreground="{Binding RoleColor}"
                                               FontFamily="Segoe UI Semibold" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Created date -->
                    <DataGridTextColumn Header="NGÀY TẠO"
                                        Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#8A93B2"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="14,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="TRẠNG THÁI" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                    <Ellipse Width="7" Height="7"
                                             Fill="{Binding StatusColor}"
                                             VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding StatusColor}"
                                               FontFamily="Segoe UI Semibold" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ACTIONS -->
                    <DataGridTemplateColumn Header="THAO TÁC" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            Margin="10,0" HorizontalAlignment="Left">

                                    <!-- Edit -->
                                    <Button Content="✏ Sửa"
                                            Style="{StaticResource BtnEdit}"
                                            Margin="0,0,8,0"
                                            Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            />

                                    <!-- Delete -->
                                    <Button Content="🗑 Xóa"
                                            Style="{StaticResource BtnDelete}"
                                            Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- =========================================================
             ROW 3 – FOOTER / PAGER
             ========================================================= -->
        <Border Grid.Row="3"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <TextBlock x:Name="txtPagerInfo"
                           Text="{Binding PagerInfo}"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnPrevPage" Content="← Trước"
                            Style="{StaticResource BtnPrimary}"
                            Background="#22263A" Margin="0,0,8,0"
                            Command="{Binding PrevPageCommand}"
                            IsEnabled="{Binding CanPrevPage}"/>
                    <Border Background="#4F8EF7" CornerRadius="6" Padding="14,9" Margin="0,0,8,0">
                        <TextBlock Text="{Binding CurrentPage}" FontFamily="Segoe UI Semibold" FontSize="13"
                                   Foreground="White"/>
                    </Border>
                    <Button x:Name="btnNextPage" Content="Tiếp →"
                            Style="{StaticResource BtnPrimary}"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanNextPage}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
