<Window x:Class="EWMS_WPF.Views.Admin.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sản phẩm"
        Height="524" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1D27">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="txtTitle" Text="Thêm sản phẩm" FontSize="18" FontWeight="SemiBold"
                   Foreground="#F1F5F9" Margin="0,0,0,16"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="Tên sản phẩm *" Foreground="#8A93B2" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="txtName" Padding="8" Margin="0,0,0,10"/>

            <TextBlock Text="Danh mục" Foreground="#8A93B2" FontSize="12" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbCategory" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryId"
                      Padding="8" Margin="0,0,0,10"/>

            <TextBlock Text="Đơn vị" Foreground="#8A93B2" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="txtUnit" Padding="8" Margin="0,0,0,10"/>

            <TextBlock Text="Giá vốn" Foreground="#8A93B2" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="txtCost" Padding="8" Margin="0,0,0,10"/>

            <TextBlock Text="Giá bán" Foreground="#8A93B2" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="txtSell" Padding="8" Margin="0,0,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" Width="100" Margin="0,0,8,0" Padding="10,8" Click="BtnCancel_Click"
                    Background="#2E3348" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Lưu" Width="100" Padding="10,8" Click="BtnSave_Click"
                    Background="#4F8EF7" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
