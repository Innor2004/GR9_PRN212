<UserControl x:Class="EWMS_WPF.Views.PurchaseOrder.PurchaseOrderDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="txtTitle" Text="Purchase Order Details" 
                              FontSize="24" FontWeight="Bold"/>
                    <TextBlock x:Name="txtStatus" FontSize="14" Margin="0,5,0,0" FontWeight="SemiBold"/>
                </StackPanel>
                <Button Content="← Back" HorizontalAlignment="Right" Padding="15,8"
                       Click="BtnBack_Click"/>
            </Grid>

            <!-- PO Info -->
            <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" 
                   CornerRadius="5" Padding="20" Margin="0,0,0,20" Background="#F9F9F9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Supplier:" FontWeight="SemiBold" Foreground="#666"/>
                        <TextBlock x:Name="txtSupplier" FontSize="16" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Created Date:" FontWeight="SemiBold" Foreground="#666"/>
                        <TextBlock x:Name="txtCreatedDate" FontSize="16" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Total Amount:" FontWeight="SemiBold" Foreground="#666"/>
                        <TextBlock x:Name="txtTotalAmount" FontSize="16" Margin="0,5,0,0" 
                                  FontWeight="Bold" Foreground="#2196F3"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Products -->
            <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PRODUCTS" FontSize="14" FontWeight="Bold" Foreground="#666"/>

                    <DataGrid Grid.Row="2" x:Name="dgProducts" 
                             AutoGenerateColumns="False"
                             IsReadOnly="True"
                             CanUserAddRows="False"
                             Height="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding Product.ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat='{}{0:N0} VND'}" Width="150"/>
                            <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat='{}{0:N0} VND'}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
