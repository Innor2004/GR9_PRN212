<UserControl x:Class="EWMS_WPF.Views.PurchaseOrder.PurchaseOrderCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EWMS_WPF.Views.PurchaseOrder">
    
    <UserControl.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Create New Purchase Order" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Fill in the information below" 
                          FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Order Info -->
            <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" 
                   CornerRadius="5" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Supplier *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Suppliers}" 
                                 SelectedItem="{Binding SelectedSupplier}"
                                 DisplayMemberPath="SupplierName"
                                 Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Expected Receiving Date *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding ExpectedDate}" Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,15,0,0">
                        <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                                Height="60" TextWrapping="Wrap" 
                                AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Products Section -->
            <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" 
                   CornerRadius="5" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Products *" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <!-- Add Product Row -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" ItemsSource="{Binding Products}"
                                 SelectedItem="{Binding SelectedProduct}"
                                 DisplayMemberPath="ProductName"
                                 Height="35"/>
                        <TextBox Grid.Column="2" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                Height="35" VerticalContentAlignment="Center"
                                TextAlignment="Center"/>
                        <Button Grid.Column="4" Content=" Add" 
                               Padding="20,8" Background="#4CAF50" Foreground="White"
                               Command="{Binding AddProductCommand}"/>
                    </Grid>

                    <!-- Products DataGrid -->
                    <DataGrid Grid.Row="2" ItemsSource="{Binding ProductItems}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             Height="250">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat='{}{0:N0} VND'}" Width="130" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='{}{0:N0} VND'}" Width="130" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Actions" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Remove" 
                                               Background="#F44336" Foreground="White"
                                               Padding="10,5"
                                               Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding ProductId}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Padding="20,10" Margin="0,0,10,0"
                       Click="BtnCancel_Click"/>
                <Button Content="Create Purchase Order" Padding="20,10"
                       Background="#2196F3" Foreground="White" FontWeight="SemiBold"
                       Command="{Binding SaveCommand}"
                       IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
