<UserControl x:Class="EWMS_WPF.Views.StockIn.StockInReceiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Receive Goods from Purchase Order" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="{Binding PurchaseOrderInfo}" FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- PO Details -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15" Background="#F9F9F9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="PO ID:" FontWeight="Bold" FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding PurchaseOrder.PurchaseOrderId}" FontSize="13" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Supplier:" FontWeight="Bold" FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding PurchaseOrder.Supplier.SupplierName}" FontSize="13" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Order Date:" FontWeight="Bold" FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding PurchaseOrder.CreatedAt, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="13" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="Status:" FontWeight="Bold" FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding PurchaseOrder.Status}" FontSize="13" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Products Grid -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
            <DataGrid ItemsSource="{Binding ReceiveItems}" 
                     AutoGenerateColumns="False"
                     CanUserAddRows="False"
                     RowHeight="50"
                     AlternatingRowBackground="#F9F9F9">
                
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product Code" Binding="{Binding Product.ProductCode}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding Product.ProductName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Ordered Qty" Binding="{Binding OrderedQuantity}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Already Received" Binding="{Binding AlreadyReceivedQuantity}" Width="130" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingQuantity}" Width="100" IsReadOnly="True"/>
                    
                    <DataGridTemplateColumn Header="Receive Qty" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ReceiveQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                        TextAlignment="Center" VerticalContentAlignment="Center"
                                        BorderThickness="1" BorderBrush="#DDD"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Location" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding AvailableLocations}" 
                                         SelectedItem="{Binding SelectedLocation, UpdateSourceTrigger=PropertyChanged}"
                                         DisplayMemberPath="LocationCode"
                                         BorderThickness="1" BorderBrush="#DDD"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="← Back to List" Padding="15,8" Margin="0,0,10,0"
                   Command="{Binding BackToListCommand}"
                   Background="#9E9E9E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            
            <Button Content="✓ Confirm Receipt" Padding="15,8"
                   Command="{Binding ConfirmReceiptCommand}"
                   Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>
