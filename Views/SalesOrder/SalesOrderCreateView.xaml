<UserControl x:Class="EWMS_WPF.Views.SalesOrder.SalesOrderCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EWMS_WPF.Views.SalesOrder">
    
    <UserControl.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisConverter"/>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Create New Sales Order" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Fill in customer and product information" FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Customer Name *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" 
                                Height="35" VerticalContentAlignment="Center" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Phone *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                                Height="35" VerticalContentAlignment="Center" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,15,0,0">
                        <TextBlock Text="Address" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding CustomerAddress, UpdateSourceTrigger=PropertyChanged}"
                                Height="35" VerticalContentAlignment="Center" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,15,0,0">
                        <TextBlock Text="Expected Delivery Date *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding ExpectedDeliveryDate}" Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,15,0,0">
                        <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                Height="35" VerticalContentAlignment="Center" Padding="5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Products *" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" ItemsSource="{Binding Products}"
                                 SelectedItem="{Binding SelectedProduct}"
                                 DisplayMemberPath="ProductName" Height="35"/>
                        <TextBox Grid.Column="2" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                Height="35" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="4" Content="+ Add Product" Padding="20,8" 
                               Background="#4CAF50" Foreground="White"
                               Command="{Binding AddProductCommand}"/>
                    </Grid>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding ProductItems}"
                             AutoGenerateColumns="False" CanUserAddRows="False" Height="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Available" Binding="{Binding AvailableQty}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat='{}{0:N0}'}" Width="120"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='{}{0:N0}'}" Width="120" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Remove" Background="#F44336" Foreground="White" Padding="10,5"
                                               Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding ProductId}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="3" Text="{Binding InventoryWarning}" 
                              Margin="0,10,0,0" FontSize="12" Foreground="#F44336" FontWeight="SemiBold"
                              TextWrapping="Wrap" Visibility="{Binding InventoryWarning, Converter={StaticResource StringToVisConverter}}"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Padding="20,10" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                <Button Content="Create Sales Order" Padding="20,10"
                       Background="#2196F3" Foreground="White" FontWeight="SemiBold"
                       Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
